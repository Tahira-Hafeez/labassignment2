<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="\css\adminDash.css">
</head>
<body>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h2>   Admin</h2>
    <a href="/admin">📋 Dashboard</a>
    <a href="/admin/addProduct">➕ Add Product</a>
    <a href="/admin/edit">✏️ Edit Product</a>
    <a href="/">🌐 View Site</a>
  </div>

  <!-- MAIN CONTENT -->
  <div class="main">
    <h1>Product Dashboard</h1>

    <table>
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(product) { %>
        <tr>
          <td><img class="thumb" src="<%= product.image %>" alt="<%= product.name %>"></td>
          <td><%= product.name %></td>
          <td><%= product.category %></td>
          <td>$<%= product.price.toFixed(2) %></td>
          <td><%= product.rating %>/5</td>
          <td><%= product.stock %></td>
          <td>
            <a href="/admin/edit/<%= product._id %>" class="edit-btn">Edit</a>

            <!-- DELETE FORM with confirmation -->
            <form action="/admin/products/<%= product._id %>?_method=DELETE"
                  method="POST" style="display:inline"
                  onsubmit="return confirm('Are you sure you want to delete <%= product.name %>?')">
              <button type="submit" class="delete-btn">Delete</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

</body>
</html>